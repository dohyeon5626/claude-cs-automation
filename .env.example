# .env — config.yml 에서 ${VAR} 로 참조하는 값들의 실제 내용.
# 이 파일을 .env 로 복사하고 본인 환경에 맞춰 채우세요. .env 는 .gitignore 에
# 들어 있어 커밋되지 않습니다. 셸에서 이미 export 된 환경변수가 있으면 그 값이
# 우선합니다 (여기 적은 값은 무시).

# 예) config.yml 에서 password: ${ORDER_DB_PASSWORD} 로 참조
ORDER_DB_PASSWORD=changeme

# 예) config.yml 에서 password: ${ADMIN_PASSWORD} 로 참조
ADMIN_PASSWORD=changeme
